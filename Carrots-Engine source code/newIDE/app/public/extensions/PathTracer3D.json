  "eventsBasedBehaviors": [
    {
      "description": "Moves objects along a specified loop path.",
      "fullName": "3D path tracer",
      "helpPath": "",
      "iconUrl": "data:image/svg+xml;base64,",
      "name": "PathTracer3D",
      "objectType": "",
      "previewIconUrl": "https://asset-resources.gdevelop.io/public-resources/Icons/Line Hero Pack/Master/SVG/Graphic Design/413f6c5ff356780893ee1abeeb8c05d71a4bcbfc21ac0d1f325de45f9253a809_Graphic Design_bezier_curve.svg",
      "eventsFunctions": [
        {
          "fullName": "",
          "functionType": "Action",
          "name": "onCreated",
          "sentence": "",
          "events": [
            {
              "type": "BuiltinCommonInstructions::JsCode",
              "inlineCode": [
                "const Object2D = objects[0];\r",
                "const Object3D = Object2D.get3DRendererObject();\r",
                "const Behavior = Object2D.getBehavior(\"PathTracer3D\");\r",
                "const Scene = runtimeScene.getLayer(Object2D.getLayer()).getRenderer().getThreeScene();\r",
                "const Path = Behavior._getPath();\r",
                "// const Tension = Behavior._getTension();// centripetalを使用するので無効\r",
                "const Debug = Behavior._getDebug();\r",
                "const Points = [];\r",
                "\r",
                "Path.trim().split('\\n').forEach((L, i) => {\r",
                "  const Nums = L\r",
                "    .split(',')\r",
                "    .map(s => s.trim())\r",
                "    .filter(s => s !== '')\r",
                "    .map(Number);\r",
                "  // 空行、数値以外は無視\r",
                "  if (Nums.length === 0 || Nums.some(isNaN)) {\r",
                "    return;\r",
                "  }\r",
                "  // 要素数が足りない場合は 0 で補完\r",
                "  const [X = 0, Y = 0, Z = 0] = Nums;\r",
                "  Points.push(new THREE.Vector3(X, Y, Z));\r",
                "});\r",
                "\r",
                "const Curve = new THREE.CatmullRomCurve3(Points, true, \"centripetal\");\r",
                "Object3D.userData._Path3D = {Curve, Progress:0};\r",
                "\r",
                "// Debug\r",
                "if (Debug) {\r",
                "  const CurvePoints = Curve.getPoints(Points.length * 10);\r",
                "  const LineGeometry = new THREE.BufferGeometry().setFromPoints(CurvePoints);\r",
                "  const LineBasicMaterial = new THREE.LineBasicMaterial({color: 0xff0000});\r",
                "  Scene.add(new THREE.Line(LineGeometry, LineBasicMaterial));\r",
                "  // \r",
                "  const PointsMaterial = new THREE.PointsMaterial({color: 0x00ff00, size: 8});\r",
                "  const PointGeometry = new THREE.BufferGeometry().setFromPoints(Points);\r",
                "  Scene.add(new THREE.Points(PointGeometry, PointsMaterial));\r",
                "}\r",
                "\r",
                ""
              ],
              "parameterObjects": "Object",
              "useStrict": true,
              "eventsSheetExpanded": true
            }
          ],
          "parameters": [
            {
              "description": "Object",
              "name": "Object",
              "type": "object"
            },
            {
              "description": "Behavior",
              "name": "Behavior",
              "supplementaryInformation": "PathTracer3D::PathTracer3D",
              "type": "behavior"
            }
          ],
          "objectGroups": []
        },
        {
          "fullName": "",
          "functionType": "Action",
          "name": "doStepPreEvents",
          "sentence": "",
          "events": [
            {
              "type": "BuiltinCommonInstructions::JsCode",
              "inlineCode": [
                "const Object2D = objects[0];\r",
                "const Object3D = Object2D.get3DRendererObject();\r",
                "const Behavior = Object2D.getBehavior(\"PathTracer3D\");\r",
                "const Speed = Behavior._getSpeed();\r",
                "const Turn = Behavior._getTurn();\r",
                "const Path3D = Object3D.userData._Path3D;\r",
                "\r",
                "// 進行度を更新（0〜1でループ）\r",
                "const Rate = (Speed * (Object2D.getElapsedTime() / 1000)) / Path3D.Curve.getLength();\r",
                "Path3D.Progress = ((Path3D.Progress + Rate) % 1 + 1) % 1;// 逆方向対応\r",
                "// 位置を設定\r",
                "const Position = Path3D.Curve.getPointAt(Path3D.Progress);\r",
                "Object3D.position.set(Position.x, Position.y, Position.z);\r",
                "//\r",
                "Object2D.setCenterXInScene(Position.x);\r",
                "Object2D.setCenterYInScene(Position.y);\r",
                "Object2D.setCenterZInScene(Position.z);\r",
                "\r",
                "// 進行方向を向かせたい場合（非ワールド座標）\r",
                "if (Turn) {\r",
                "  Position.add(Path3D.Curve.getTangentAt(Path3D.Progress));\r",
                "  const dx = Position.x - Object3D.position.x;\r",
                "  const dy = Position.y - Object3D.position.y;\r",
                "  const dz = Position.z - Object3D.position.z;\r",
                "  const dxy = Math.sqrt(dx * dx + dy * dy);\r",
                "  // ZYX euler: z = 方位角, y = -仰角, x = 0\r",
                "  const rz = Math.atan2(dy, dx);\r",
                "  const ry = -Math.atan2(dz, dxy);\r",
                "  // const rx = 0;\r",
                "  Object3D.rotation.set(0, ry, rz);\r",
                "  // Object2D への反映\r",
                "  Object2D._rotationX = gdjs.toDegrees(0);\r",
                "  Object2D._rotationY = gdjs.toDegrees(ry);\r",
                "  Object2D.setAngle(gdjs.toDegrees(rz));\r",
                "}\r",
                "\r",
                ""
              ],
              "parameterObjects": "Object",
              "useStrict": true,
              "eventsSheetExpanded": true
            }
          ],
          "parameters": [
            {
              "description": "Object",
              "name": "Object",
              "type": "object"
            },
            {
              "description": "Behavior",
              "name": "Behavior",
              "supplementaryInformation": "PathTracer3D::PathTracer3D",
              "type": "behavior"
            }
          ],
          "objectGroups": []
